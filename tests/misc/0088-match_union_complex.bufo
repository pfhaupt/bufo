//! THIS IS A TEST PROGRAM
//! RUNTIME
//! SUCCESS

import "prelude.bufo";
import "libc.bufo";

union Bez {
    Flag(i32),
}

struct Bar {
    bez: Bez;
}

union Foo {
    A(Bar),
    B(u64, u32),
    C { c: u8 },
}

func main(argc: i32, argv: &&char) -> i32 {
    let a = Foo::A(Bar { bez: Bez::Flag(12) });
    match (&a) {
        &Foo::A(Bar { Bez::Flag(val) }) => {
            assert(val == 12, "val != 12");
            val = 17;
            C::printf("A write yep\n");
        }
        _ => { return 1; }
    }
    match (a) {
        Foo::A(Bar { Bez::Flag(val) }) => {
            assert(val == 17, "val != 17");
            C::printf("A read yep\n");
        }
        _ => { return 1; }
    }
    // it's all just bytes in the memory, we can massage them as we want
    // union layout: u8 tag + padding + [u8; N] data
    // Foo::A is [u8; 7 bytes pad; [u8; 3 bytes pad; i32]], so we just skip
    // the tags and the padding and retrieve the data with a simple cast
    let foo_align: usize = 8;
    let bez_align: usize = 4;
    let ptr = ((&a as &u8 + foo_align) + bez_align) as &i32;
    let val = *ptr;
    assert(val == 17);
    return 0;
}

