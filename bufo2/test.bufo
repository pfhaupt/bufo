
struct Foo {
    length: List(i32);
}

struct List($T) {
    // Pointer to the heap
    elements: *$T;
    // How many elements are in the list
    length: usize;
    capacity: usize;
}

// NOTE(2026-03-03): After we get the compiler to actually do things,
//                   it should be able to infer the `@expand` because we
//                   pass a `Code`. But this form should always work.
func assert(cond: Code) @expand {
    if (!#insert cond.str) {
        print("%: error: Assertion `%` failed!\n", cond.loc, cond.str);
        exit(1);
    }
}
func assert(cond: Code, msg: string) @expand {
    if (!#insert cond.str) {
        print("%: error: Assertion `%` failed: %\n", cond.loc, cond.str, msg);
        exit(1);
    }
}

func bar(a: $T, b: $V) {
}

func fun(b: i32, a: *List($T)) {}

func push(list: *List($T), elem: $T) {
    // if (list.length >= list.capacity) {
    //     let new_cap = list.capacity * 2;
    //     if (new_cap == 0) new_cap = 16;
    //     list.elements = realloc(list.elements, new_cap * sizeof(elem));
    //     assert(list.elements != null, "Could not allocate List elements");
    //     list.capacity = new_cap;
    // }
    // list.elements[list.length] = elem;
    // list.length += 1;
}

func push_elem() -> str {
    return "push(&list, 123);";
}

func get_code() -> str {
    return "{ let n: i32 = 123; n }";
}

func main() {
    comptime list_of_i32 = List(i32);
    comptime foo = "let bar: i32 = 1";
    let list: list_of_i32 = blank;
    let s = #run {
        #insert,expr #run get_code()
    };
    bar(s, list);
    bar(list, s);
    fun(123, &list);
    #insert "push(&list, s);";
    #insert foo;                 // let bar = 1;
    #insert "push(&list, bar);"; // push(&list, bar);
    #insert #run push_elem();    // push(&list, 123);
}
